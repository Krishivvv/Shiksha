# Required — get a free key at https://aistudio.google.com
GOOGLE_API_KEY=your_google_ai_studio_key_here

# Optional — if set, video generation uses KodeKloud API instead of Gemini
KODEKLOUD_API_KEY=your_kodekloud_api_key_here
KODEKLOUD_API_KEY_BACKUP=your_backup_kodekloud_api_key_here
KODEKLOUD_BASE_URL=https://api.ai.kodekloud.com/v1
KODEKLOUD_MODEL=google/gemini-3.1-pro-preview

# Required — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_random_64_char_hex_string

# Required — local Redis or Upstash free tier (https://upstash.com)
REDIS_URL=redis://127.0.0.1:6379/0

# Optional — defaults to SQLite (fine for hackathon)
DATABASE_URL=sqlite:///site.db

# Optional — comma-separated allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional — only needed if Chrome is not on PATH
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
