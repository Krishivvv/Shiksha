# ── Environment ──────────────────────────────────────────────────────────────
# Set to "production" on your server. Controls secure cookies, HSTS, and whether
# the task queue is used by default.
FLASK_ENV=development

# ── Secret (required) ────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_random_64_char_hex_string

# ── LLM provider — provide at least one ──────────────────────────────────────
# Google Gemini (used for quizzes and as the generation fallback).
GOOGLE_API_KEY=
# Optional KodeKloud OpenAI-compatible API (primary generation provider if set).
KODEKLOUD_API_KEY=
KODEKLOUD_API_KEY_BACKUP=
KODEKLOUD_BASE_URL=https://api.ai.kodekloud.com/v1
KODEKLOUD_MODEL=google/gemini-3.1-pro-preview

# ── Datastores ───────────────────────────────────────────────────────────────
# Local Redis or Upstash free tier (https://upstash.com). Required in production
# for the rate limiter, progress store, and task queue.
REDIS_URL=redis://127.0.0.1:6379/0
# SQLite is fine for dev. Use Postgres in production, e.g.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///site.db

# ── CORS — comma-separated allowed origins (set your real domain in prod) ─────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Background task queue ────────────────────────────────────────────────────
# Defaults to ON in production. Run a worker with: rq worker video --url $REDIS_URL
# USE_TASK_QUEUE=true

# ── Artifact storage: local | s3 (S3 / Cloudflare R2) ────────────────────────
STORAGE_BACKEND=local
# S3_BUCKET=shishka-artifacts
# S3_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com   # Cloudflare R2
# S3_REGION=auto
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Optional tuning ──────────────────────────────────────────────────────────
# LLM_TIMEOUT=120
# FFMPEG_TIMEOUT=300
# MAX_CONTENT_LENGTH_MB=50
# Only needed if Chrome is not on PATH
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
